+static bool shouldKeepWifiServicesActive() {
+    if (!uploader || !uploader->getScheduleManager()) {
+        return true;
+    }
+
+    ScheduleManager* sm = uploader->getScheduleManager();
+
+    if (!sm->isTimeSynced()) return true;
+    if (sm->isSmartMode()) return true;
+
+    return sm->isInUploadWindow();
+}

+static void stopWifiServices() {
+    if (!g_wifiServicesActive) return;
+
+#ifdef ENABLE_WEBSERVER
+    if (webServer && webServer->isRunning()) {
+        webServer->stop();
+    }
+#endif
+
+    wifiManager.stopRadio();
+    g_wifiServicesActive = false;
+}

+static bool startWifiServices() {
+    if (g_wifiServicesActive) return true;
+
+    if (!wifiManager.connectStation(config.getWifiSSID(), config.getWifiPassword())) {
+        return false;
+    }
+
+#ifdef ENABLE_WEBSERVER
+    if (webServer && !webServer->isRunning()) {
+        webServer->begin();
+    }
+#endif
+
+    g_wifiServicesActive = true;
+    return true;
+}

+static void updateScheduledWifiWindow() {
+    if (!uploader || uploadTaskRunning) return;
+
+    ScheduleManager* sm = uploader->getScheduleManager();
+
+    if (!sm || sm->isSmartMode() || !sm->isTimeSynced()) return;
+
+    bool shouldBeActive = sm->isInUploadWindow();
+
+    if (shouldBeActive && !g_wifiServicesActive) {
+        startWifiServices();
+    }
+    else if (!shouldBeActive && g_wifiServicesActive) {
+        stopWifiServices();
+    }
+}

