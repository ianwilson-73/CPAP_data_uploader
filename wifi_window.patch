+void WiFiManager::stopRadio() {
+    if (mdnsStarted) {
+        MDNS.end();
+        mdnsStarted = false;
+    }
+
+    WiFi.disconnect(true, true);
+    delay(20);
+    esp_wifi_stop();
+    WiFi.mode(WIFI_OFF);
+    connected = false;
+}

